# Backend (SUB-05) environment. Copy to .env and adjust. All vars are prefixed BACKEND_.
# No secrets / paid-API keys belong here — the backend never calls an LLM at runtime (PROJECT_SPEC §4.3).

# --- HTTP server ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENVIRONMENT=development
BACKEND_API_PREFIX=/api/v1

# Comma-separated frontend origins allowed by CORS (Vite dev server + Docker frontend).
BACKEND_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Simulation engine (the seam to SUB-01) ---
# fake = deterministic stub (runnable now); mesa = real engine once SUB-01 ships.
BACKEND_SIM_ENGINE=fake
BACKEND_TICK_INTERVAL_SECONDS=1.0
BACKEND_SNAPSHOT_BUFFER_SIZE=2000
BACKEND_DEFAULT_POPULATION=10000

# --- Metadata persistence (SQLite — NOT Postgres for v1, per PROJECT_SPEC §5.3) ---
BACKEND_METADATA_DB_PATH=data/backend_metadata.sqlite
